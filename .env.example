# ===========================================
# OdontoTask - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores

# ---------- Anthropic (IA) ----------
ANTHROPIC_API_KEY=sk-ant-...

# ---------- TLDV ----------
TLDV_API_KEY=
TLDV_WEBHOOK_SECRET=

# ---------- Notion ----------
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=

# ---------- Banco de Dados ----------
# Railway fornece automaticamente via addon PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/odontotask

# ---------- App ----------
NEXTAUTH_SECRET=gere-um-secret-forte-aqui
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Polling (minutos) ----------
TLDV_POLLING_INTERVAL=30
